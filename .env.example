# API Configuration
VITE_API_BASE_URL=/api

# Braintree (dev: Vite plugin serves client token at GET /api/braintree/client-token)
# Add these to .env or .env.local - do NOT use VITE_ prefix for private key (server-only)
BRAINTREE_MERCHANT_ID=your_merchant_id
BRAINTREE_PUBLIC_KEY=your_public_key
BRAINTREE_PRIVATE_KEY=your_private_key
# Optional: production | sandbox (default: sandbox)
# BRAINTREE_ENVIRONMENT=sandbox

# Environment
VITE_ENV=development
VITE_APP_NAME=SW Couriers

# Optional: override sidebar version (baked in at build time)
# - Unset: auto-generated on each `npm run build`, e.g. v0.0.0-20260520.8727946
# - CI tag deploy: set to tag only, e.g. v1.0.1
# VITE_APP_VERSION=v1.0.1

# Optional: Override Braintree client token URL (e.g. your backend)
# VITE_BRAINTREE_CLIENT_TOKEN_URL=https://your-api.com/braintree/client-token
